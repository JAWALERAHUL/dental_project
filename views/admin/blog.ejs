
<%-include('header.ejs')%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">blog</h1>
                
              </div>
            </div>
            
          </div>

          <section class="panel">
            <form action="/admin/blog_save" method="post" enctype="multipart/form-data">
             <label>photo</label>
             <input type="file" class="form-control mb-4" name="bphoto">
             <label>date</label>
             <input type="date" class="form-control mb-4" name="bdate">
             <label>title</label>
             <input type="text" class="form-control mb-4" name="btitle">
             <label>description</label>
             <textarea class="form-control mb-4" name="bdesc"></textarea>
             <button class="btn btn-primary">save</button>
             </form>

              <table class="table table-border mt-5">
              <tr>
                <th>sr.no</th>
                <th>image</th>
                  <th>date</th>
                  <th>title</th>
                <th>description</th>
                <th>status</th>
              </tr>
<% for(var i=0;i<data.length;i++){ %>
          <tr> <th><%= i+1; %></th>
                <th>
                  <img src=" /images/<%= data[i].bphoto; %>" height="70px">
                </th>
                <th><%= data[i].bdate; %></th>
                <th><%= data[i].btitle; %></th>
                <th><%= data[i].bdesc; %></th>
                <th>
                  
                  <a href="/admin/blog_delete/<%= data[i].blog_id %>/<%= data[i].bphoto %>">
    <button class="btn">delete</button>
</a>

<a href="/admin/blog_edit/<%= data[i].blog_id %>">
    <button class="btn">edit</button>
</a>


                </th>
              </tr>
             
           <% } %>

             </table>


        </section>
        </div>
      </main>

<%-include('footer.ejs')%>