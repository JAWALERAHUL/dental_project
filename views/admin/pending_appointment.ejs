
<%-include('header.ejs')%>
      <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">Pending Appointment</h1>
                
              </div>
            </div>
            
          </div>

          <section class="panel">
            

              <table class="table table-border mt-5">
              <tr>
                <th>sr.no</th>
                <th>name</th>
                  <th>email</th>
                  <th>service_id</th>
                <th>appointment_date</th>
                <th>status</th>
                <th>action</th>
              </tr>
<% for(var i=0;i<data.length;i++){ %>
          <tr> <th><%= i+1; %></th>
               
                <th><%= data[i].name; %></th>
                <th><%= data[i].email; %></th>
                <th><%= data[i].service_id; %></th>
                <th><%= new Date(data[i].appointment_date).toLocaleDateString('en-GB') %></th>
                <th><%= data[i].status; %></th>
                
                <th>
            <a href="/admin/reject_appointment/<%= data[i].aid %>">
    <button class="btn btn-danger">Reject</button>
</a>

<a href="/admin/confirm_appointment/<%= data[i].aid %>">
    <button class="btn btn-success">Confirm</button>
</a>


                </th>
              </tr>
             
           <% } %>

             </table>


        </section>
        </div>
      </main>

<%-include('footer.ejs')%>