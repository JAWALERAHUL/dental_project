<%-include('header.ejs')%>
     <main class="dashboard-content">
        <div class="container-fluid px-3 px-lg-4 py-4">
          <div class="page-heading">
            <div class="page-heading-copy">
              <span class="page-icon"><i class="bi bi-file-earmark" aria-hidden="true"></i></span>
              <div>
                <p class="eyebrow mb-1">Starter</p>
                <h1 class="h3 mb-1">blog update</h1>
                <p class="text-muted mb-0">A clean starter page for new admin screens.</p>
              </div>
            </div>
            
          </div>

          <section class="panel ">
            <div class="">
                <form action="/admin/blog_edit_save/<%=data.blog_id%>/<%=data.bphoto %>" method="post" enctype="multipart/form-data">
                    <label>photo</label>
                    <input type="file" name="bphoto"  class="form-control mb-4" >
                    <img src="/images/<%=data.bphoto %>" height="70px" />
                    <label>date</label>
                    <input type="date" name="bdate" value="<%=data.bdate %>" class="form-control mb-4" >
                    <label>title</label>
                    <input type="text" name="btitle" value="<%=data.btitle %>" class="form-control mb-4" >
                    <label>description</label>
                    <input type="text" name="bdescription" value="<%=data.bdescription %>" class="form-control mb-4" >
                    <button type="submit" class="btn btn-primary">update</button>
                </form>
            </div>
          </section>
        </div>
      </main>
    <%-include('footer.ejs')%>